// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  UNVERIFIED
  ACTIVE
  BANNED
}

enum Role {
  USER
  ADMIN
}

model User {
  id          Int     @id @default(autoincrement())
  email       String  @unique
  password    String

  status      Status  @default(UNVERIFIED)
  role        Role    @default(USER)

  verificationToken String? @unique
  verificationCode String? @unique

  tokens      RefreshToken[]
  vectorStorages VectorStorage[]
  vectorStorageTags VectorStorageTag[]

  verifiedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id          Int     @id @default(autoincrement())
  token       String  @unique
  userId      Int
  user        User    @relation(fields: [userId], references: [id])

  ipAddress   String?
  userAgent   String?
  device      String?

  revoked     Boolean @default(false)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("refresh_tokens")
}

model VectorStorage {
  id           String   @id @default(cuid())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  size         Int      @default(0)
  lastActiveAt DateTime @default(now())
  tags         VectorStorageTag[] @relation("VectorStorageToTag")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([userId])
  @@map("vector_storages")
}

model VectorStorageTag {
  id        String   @id @default(cuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  storages  VectorStorage[] @relation("VectorStorageToTag")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("vector_storage_tags")
}

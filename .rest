### Auth: Register
# POST {{baseUrl}}/auth/register
# Description: Registration of a new user and issuing access/refresh tokens.
# Body:
# - email: string (valid email)
# - password: string (recommended min 6 chars)
# - passwordConfirm: string (must match password)
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
	"email": "user@example.com",
	"password": "StrongPass123",
	"passwordConfirm": "StrongPass123"
}

### Auth: Login
# POST {{baseUrl}}/auth/login
# Description: JWT authorization and issuing a new access/refresh token pair.
# Body:
# - email: string
# - password: string
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
	"email": "user@example.com",
	"password": "StrongPass123"
}

### Auth: Me
# GET {{baseUrl}}/auth/me
# Description: Returns current authenticated user info.
# Header:
# - Authorization: Bearer <accessToken>
GET {{baseUrl}}/auth/me
Authorization: Bearer {{accessToken}}

### Auth: Logout
# POST {{baseUrl}}/auth/logout
# Description: Revokes current refresh token (logout current session).
# Header:
# - Authorization: Bearer <accessToken>
# Body:
# - refreshToken: string
POST {{baseUrl}}/auth/logout
Content-Type: application/json
Authorization: Bearer {{accessToken}}

{
	"refreshToken": "{{refreshToken}}"
}

### Auth: Refresh
# POST {{baseUrl}}/auth/refresh
# Description: Refresh access token using refresh token.
# Body:
# - refreshToken: string
POST {{baseUrl}}/auth/refresh
Content-Type: application/json

{
	"refreshToken": "{{refreshToken}}"
}

### Auth: Sessions
# GET {{baseUrl}}/auth/sessions
# Description: Returns all active sessions for current user.
# Header:
# - Authorization: Bearer <accessToken>
GET {{baseUrl}}/auth/sessions
Authorization: Bearer {{accessToken}}

### Auth: Revoke Session
# DELETE {{baseUrl}}/auth/sessions/:id
# Description: Revoke a specific user session by session id.
# Header:
# - Authorization: Bearer <accessToken>
DELETE {{baseUrl}}/auth/sessions/{{sessionId}}
Authorization: Bearer {{accessToken}}
